{
  "name": "deepseek-token-counter",
  "displayName": "DeepSeek Token Counter",
  "description": "Count tokens and estimate costs for DeepSeek models right in your editor",
  "version": "1.0.0",
  "publisher": "GunnarMUC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GunnarMUC/deepseek-token-counter.git"
  },
  "homepage": "https://github.com/GunnarMUC/deepseek-token-counter#readme",
  "bugs": {
    "url": "https://github.com/GunnarMUC/deepseek-token-counter/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "deepseek",
    "tokens",
    "token-counter",
    "cost",
    "ai",
    "llm"
  ],
  "activationEvents": [
    "onLanguage:plaintext",
    "onLanguage:markdown",
    "onLanguage:json",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:python",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "deepseekTokenCounter.selectModel",
        "title": "DeepSeek Token Counter: Select Model"
      },
      {
        "command": "deepseekTokenCounter.showDetails",
        "title": "DeepSeek Token Counter: Show Details"
      }
    ],
    "configuration": {
      "title": "DeepSeek Token Counter",
      "properties": {
        "deepseekTokenCounter.preferredModel": {
          "type": "string",
          "default": "deepseek-chat",
          "description": "Default DeepSeek model ID for token counting"
        },
        "deepseekTokenCounter.models": {
          "type": "array",
          "default": [],
          "description": "Custom model configurations (overrides built-in defaults)",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Model identifier"
              },
              "name": {
                "type": "string",
                "description": "Display name"
              },
              "inputPricePer1M": {
                "type": "number",
                "description": "Price per 1M input tokens (USD)"
              },
              "outputPricePer1M": {
                "type": "number",
                "description": "Price per 1M output tokens (USD)"
              }
            }
          }
        },
        "deepseekTokenCounter.assumeOutputRatio": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 1,
          "description": "Ratio of tokens assumed to be output (0 = treat all as input, 0.3 = 30% output)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run compile",
    "test": "node ./out/test/tokenizer.test.js && node ./out/test/cost.test.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.3"
  }
}
